generator client {
  provider        = "prisma-client"
  output          = "../app/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector, pg_graphql, pg_stat_statements, pgcrypto, supabase_vault, uuid_ossp(map: "uuid-ossp")]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())

  characters Character[]
  campaigns  Campaign[]
}

model Character {
  id         String   @id @default(cuid())
  userId     String
  name       String
  race       String
  class      String
  level      Int      @default(1)
  hp         Int
  maxHp      Int
  stats      Json
  spellSlots            Json?
  xp                    Int     @default(0)
  /// The ID of the spell currently being concentrated on. Null = no active concentration.
  concentrationSpellId  String?
  /// Total hit dice the character possesses (= level). Equals the number of
  /// hit dice available at full rest. Decremented by short rest healing.
  hitDiceTotal          Int     @default(1)
  /// Remaining hit dice available for short rest healing.
  /// Reset to hitDiceTotal on long rest. Must satisfy 0 ≤ remaining ≤ total.
  hitDiceRemaining      Int     @default(1)
  /// D&D 5e 2014 exhaustion level. Range: 0 (none) to 6 (dead).
  /// Incremented by executeExplorationTurn when a mandatory rest is skipped.
  /// Decremented by 1 on long rest per 5e 2014 rules.
  exhaustionLevel       Int     @default(0)
  createdAt             DateTime @default(now())

  user      User            @relation(fields: [userId], references: [id])
  campaigns Campaign[]
  inventory InventoryItem[]
}

model Campaign {
  id          String   @id @default(cuid())
  userId      String
  characterId String
  title       String
  status      String   @default("active")
  /// Party gold pieces. Integer — no fractional currency.
  /// Mutations ONLY via Prisma transactions from tool execution, never from AI narration.
  gold        Int      @default(0)
  /// The location the party is currently exploring. Null = no active exploration.
  currentLocationId  String?
  /// The specific node within the location the party occupies. Null = not in a location.
  currentNodeId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user           User           @relation(fields: [userId], references: [id])
  character      Character      @relation(fields: [characterId], references: [id])
  logs           GameLog[]
  encounters     Encounter[]
  memories       MemoryEntry[]
  quests         Quest[]
  npcs           NPC[]
  locations      Location[]
  campaignTime   CampaignTime?
  partyInventory PartyInventory?
  wildernessMap  WildernessMap[]
  travelState    TravelState?
}

model GameLog {
  id         String   @id @default(cuid())
  campaignId String
  role       String
  content    String
  createdAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id])
}

model Encounter {
  id               String   @id @default(cuid())
  campaignId       String
  status           String   @default("active")
  // "active" | "resolved" | "fled"
  round            Int      @default(1)
  currentTurnIndex Int      @default(0)
  // Zero-based index into combatants ordered by initiativeTotal DESC.
  totalDamageDealt Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  campaign   Campaign    @relation(fields: [campaignId], references: [id])
  combatants Combatant[]
  zones      Zone[]
}

model Combatant {
  id              String  @id @default(cuid())
  encounterId     String
  name            String
  isPlayer        Boolean @default(false)
  hp              Int
  maxHp           Int
  ac              Int     @default(10)
  initiativeTotal Int
  conditions      Json    @default("[]")
  // String[] of active condition names, e.g. ["Prone", "Poisoned"].
  /// Zone the combatant currently occupies. Null = zone system not active for this encounter.
  zoneId          String?

  encounter Encounter @relation(fields: [encounterId], references: [id])
  zone      Zone?     @relation(fields: [zoneId], references: [id])
}

/// Ephemeral combat zone — scoped to a single Encounter, deleted on Cascade.
model Zone {
  id          String @id @default(cuid())
  encounterId String
  name        String
  /// Grid column (0-based, left → right).
  x           Int
  /// Grid row (0-based, top → bottom).
  y           Int

  encounter  Encounter   @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  combatants Combatant[]
}

model InventoryItem {
  id          String  @id @default(cuid())
  characterId String
  name        String
  type        String
  // "weapon" | "armor" | "consumable" | "spell" | "misc"
  quantity    Int     @default(1)
  properties  Json
  /// Equipped slot name, e.g. 'MAIN_HAND' | 'OFF_HAND' | 'ARMOR' | 'ACCESSORY'.
  /// Null means the item is in the bag but not equipped.
  equippedSlot String?

  character Character @relation(fields: [characterId], references: [id])
}

model MemoryEntry {
  id         String                      @id @default(cuid())
  campaignId String
  /// Human-readable memory text injected into prompts. Max ~400 chars.
  content    String
  /// 1536-dimensional embedding from text-embedding-3-small.
  /// Stored as Unsupported until Prisma ships a native Vector scalar.
  embedding  Unsupported("vector(1536)")
  /// Relative importance weight; higher values surface this memory first.
  importance Float                       @default(1.0)
  createdAt  DateTime                    @default(now())
  updatedAt  DateTime                    @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id])

  @@index([campaignId])
}

model Quest {
  id          String   @id @default(cuid())
  campaignId  String
  title       String
  description String
  status      String   @default("active")
  // "active" | "completed" | "failed"
  /// Seed of the NPC who issued this quest. Null for quests without a named giver.
  giverId     String?
  /// Primary location the quest takes place in or leads to.
  location    String?
  /// Narrative hook — the inciting detail that draws the party in.
  hook        String?
  /// The specific objective the party must accomplish.
  objective   String?
  /// What the party stands to gain on completion.
  reward      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id])
}

model NPC {
  id         String   @id @default(cuid())
  campaignId String
  /// Stable generator seed — deterministically reproduces the full statblock
  /// via generateNPC(seed, role). Never changes after creation.
  seed       String
  /// Archetype used for statblock generation: "guard" | "bandit" | "commoner"
  role       String
  /// Denormalized from generateNPC — stored for fast display and HP-bar rendering.
  name       String
  maxHp      Int
  /// Mutable. Callers decrement this when damage is applied.
  hp         Int
  /// Armor class — denormalized from the deterministic statblock.
  ac         Int
  /// Free-form DM notes: story beats, attitudes, plot ties, last seen location.
  notes      String   @default("")
  /// Creature race, e.g. "human", "elf", "dwarf". Null for legacy records.
  race        String?
  /// Mundane profession, e.g. "blacksmith", "soldier". Null for legacy records.
  profession  String?
  /// Moral alignment, e.g. "lawful good", "chaotic neutral". Null for legacy records.
  alignment   String?
  /// Six ability scores: { STR, DEX, CON, INT, WIS, CHA }. Null for legacy records.
  abilityScores Json?
  /// Personality traits { personality, ideal, bond, flaw }. Null for legacy records.
  traits      Json?
  /// Current disposition toward the party. Range: −10 (Hostile) to +10 (Helpful).
  /// Set by rollReaction on first meeting; updated by socialCheck on social actions.
  /// Null for NPCs the party has never spoken to (reaction roll pending).
  disposition     Int?
  /// Personality Tags generated deterministically from the seed.
  /// JSON object: { motivation: string, secret: string, distinctiveTrait: string }
  /// Populated by generateNPCPersonality(seed) on first interaction.
  /// Never null after first meeting; null for legacy/unmet NPCs.
  personalityTags Json?
  /// True once the party has formally met this NPC (rollReaction has fired).
  /// Prevents duplicate reaction rolls on subsequent encounters.
  hasMetPlayer    Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id])

  /// One NPC seed is unique per campaign — UPSERT key.
  @@unique([campaignId, seed])
  @@index([campaignId])
}

model SrdMonster {
  id        String  @id
  name      String
  /// Challenge Rating as a float (0.125, 0.25, 0.5, 1–30). Null for legacy records.
  cr        Float?
  /// Creature type, e.g. "dragon", "undead", "humanoid", "beast".
  type      String?
  /// Size category: "Tiny" | "Small" | "Medium" | "Large" | "Huge" | "Gargantuan".
  size      String?
  /// Alignment string, e.g. "lawful evil", "any alignment", "unaligned".
  alignment String?
  /// Full raw JSON blob from the SRD dataset.
  data      Json

  @@index([cr])
  @@index([type])
}

model SrdSpell {
  id   String @id
  name String
  data Json
}

model SrdItem {
  id   String @id
  name String
  data Json
}

/// A procedurally generated location — a tavern, village, dungeon floor, etc.
/// Created exclusively by the `generateLocation` tool; the AI narrator may NOT
/// invent locations outside this table.
model Location {
  id          String  @id @default(cuid())
  campaignId  String
  /// Deterministic seed — the same seed always reproduces the same layout.
  seed        String
  /// Location archetype: "tavern" | "village" | "dungeon" | "wilderness" | "ruins"
  type        String
  /// Human-readable evocative name, e.g. "The Dripping Nave"
  name        String
  /// 1–3 sentence atmospheric description.
  description String
  /// Optional parent — e.g. a dungeon floor's parent is the dungeon entrance.
  parentId    String?
  createdAt   DateTime @default(now())

  campaign Campaign       @relation(fields: [campaignId], references: [id])
  parent   Location?      @relation("LocationHierarchy", fields: [parentId], references: [id])
  children Location[]     @relation("LocationHierarchy")
  nodes    LocationNode[]
  edges    LocationEdge[]

  @@index([campaignId])
  @@unique([campaignId, seed])
}

/// A single room, area, or zone within a Location.
/// Part of the node graph that players navigate.
model LocationNode {
  id          String  @id @default(cuid())
  locationId  String
  /// Index within the generated graph (0 = entry node).
  index       Int
  /// Evocative name, e.g. "The Whispering Gallery"
  name        String
  /// Brief atmospheric description (≤ 300 chars).
  description String
  /// Feature tag: "empty" | "npc" | "hazard" | "treasure" | "quest_hook" | "rest" | "shop" | "exit"
  feature     String  @default("empty")
  /// Optional NPC seed — links to NPC generation for this node's inhabitant.
  npcSeed     String?
  /// Optional extra feature data (hazard details, shop inventory hints, etc.)
  featureData Json    @default("{}")
  /// Grid position for visual rendering (column, 0-based).
  x           Int
  /// Grid position for visual rendering (row, 0-based).
  y           Int

  location    Location       @relation(fields: [locationId], references: [id], onDelete: Cascade)
  edgesFrom   LocationEdge[] @relation("EdgeFrom")
  edgesTo     LocationEdge[] @relation("EdgeTo")

  @@unique([locationId, index])
  @@index([locationId])
}

/// An edge connecting two LocationNodes — defines navigable passages.
/// Edges are bidirectional: if A→B exists, B→A is implicit.
model LocationEdge {
  id          String @id @default(cuid())
  locationId  String
  fromNodeId  String
  toNodeId    String
  /// Passage type: "open" | "door" | "locked" | "hidden" | "collapsed"
  passageType String @default("open")

  location Location     @relation(fields: [locationId], references: [id], onDelete: Cascade)
  fromNode LocationNode @relation("EdgeFrom", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode   LocationNode @relation("EdgeTo", fields: [toNodeId], references: [id], onDelete: Cascade)

  @@unique([fromNodeId, toNodeId])
  @@index([locationId])
}

/// Tracks the campaign's absolute temporal state for the OSR Exploration Time Engine.
/// One record per campaign. totalTurns is monotonically increasing — never decremented.
/// All mutations occur inside prisma.$transaction — no partial writes.
model CampaignTime {
  id          String @id @default(cuid())
  campaignId  String @unique

  /// Total dungeon turns elapsed since campaign start. 1 turn = 10 minutes.
  totalTurns  Int @default(0)

  /// Derived display field: floor(totalTurns / 6). Stored for query efficiency.
  /// Must always equal floor(totalTurns / TURNS_PER_HOUR). Updated atomically.
  totalHours  Int @default(0)

  /// Turns accumulated in the current rest cycle (0–6).
  /// Reaching REST_INTERVAL_TURNS (6) makes rest mandatory before the next turn.
  /// Reset to 0 by applyRest(). Capped at 6 to prevent integer overflow.
  turnsSinceRest Int @default(0)

  /// Turns accumulated in the current encounter-check cycle (0–1).
  /// An encounter roll fires when this reaches ENCOUNTER_CHECK_INTERVAL_TURNS (2).
  /// Resets modulo 2 after each check fires.
  turnsSinceEncounterCheck Int @default(0)

  /// Turns accumulated in the current ration cycle (0–143).
  /// Ration consumption fires when this reaches RATION_INTERVAL_TURNS (144).
  /// Resets modulo 144 after each consumption fires.
  turnsSinceRation Int @default(0)

  updatedAt DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id])
}

/// Tracks consumable exploration resources for the OSR Exploration Time Engine.
/// One record per campaign. Quantities are non-negative integers — never fractional.
/// The AI narrator MUST NOT mutate this table directly.
model PartyInventory {
  id          String @id @default(cuid())
  campaignId  String @unique

  /// Unlit torches in the pack. Each provides TORCH_DURATION_TURNS (6) of light when lit.
  /// Seeded at INITIAL_TORCHES_PER_PLAYER × partySize on campaign creation.
  torches     Int @default(0)

  /// Oil flasks in the pack. Each provides OIL_DURATION_TURNS (24) of light when burning.
  /// Not seeded at campaign creation — must be purchased in-world.
  oilFlasks   Int @default(0)

  /// Total rations across all party members.
  /// Seeded at INITIAL_RATIONS_PER_PLAYER × partySize on campaign creation.
  rations     Int @default(0)

  /// Active light source currently being consumed. "torch" | "lantern" | "none".
  /// "none" means the party is in darkness — may trigger penalties.
  activeLightSource String @default("none")

  /// Turns remaining on the active light source before it burns out.
  /// At 0, consumeResources() auto-selects the next source (torch priority — Q3).
  lightSourceTurnsRemaining Int @default(0)

  updatedAt DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id])
}

/// One record per unique hex coordinate per campaign — the wilderness map grid.
/// Created on first visit (infinite on-demand generation — Q1).
/// The AI narrator MUST NOT invent hex contents. Hex is real only once this record exists
/// and discovered = true.
model WildernessMap {
  id         String  @id @default(cuid())
  campaignId String

  /// Azgaar cube coordinate Q axis. s = -q - r (never stored).
  q          Int
  /// Azgaar cube coordinate R axis.
  r          Int

  /// Canonical terrain type: plains | forest | hills | mountain | swamp | desert | coast | tundra | taiga
  terrain    String
  /// Azgaar biome label for narrative flavor (e.g. "temperate broadleaf forest").
  biome      String
  /// Elevation 0–100. Used with moisture to derive terrain + biome deterministically.
  elevation  Int     @default(0)
  /// Moisture 0–100. Used with elevation to derive terrain + biome deterministically.
  moisture   Int     @default(0)

  /// True once the party has physically occupied this hex.
  /// Write-once-forward — never reverts to false.
  discovered Boolean @default(false)
  /// True if revealed from an adjacent hex (fog-of-war lite).
  /// Write-once-forward — never reverts to false.
  scouted    Boolean @default(false)

  /// Optional overworld feature: "dungeon_entrance" | "village" | "ruins" | "shrine" | null
  feature    String?
  /// FK → Location if the feature has been expanded into a generated Location record.
  locationId String?

  /// Deterministic content seed — derived from campaignId + q + r.
  /// The same coordinate always generates identical terrain, biome, elevation, moisture, and feature.
  seed       String

  createdAt DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id])

  /// One hex per coordinate per campaign.
  @@unique([campaignId, q, r])
  @@index([campaignId])
}

/// Tracks the campaign's overworld temporal and spatial state.
/// One record per campaign. All mutations occur inside prisma.$transaction — no partial writes.
/// Coexists with CampaignTime (Milestone O). Active system inferred from Campaign.currentLocationId:
///   non-null → CampaignTime governs (dungeon); null + this record exists → TravelState governs.
model TravelState {
  id         String @id @default(cuid())
  campaignId String @unique

  /// Current party position — Azgaar cube coordinate Q.
  currentQ   Int @default(0)
  /// Current party position — Azgaar cube coordinate R.
  currentR   Int @default(0)

  /// Watch index within the current day (0–5). 5 = mandatory Night rest.
  currentWatch Int @default(0)
  /// Monotonically increasing watch counter. Never decremented.
  totalWatches Int @default(0)
  /// floor(totalWatches / 6). Stored for query efficiency.
  totalDays    Int @default(0)

  /// How many travel-action watches have been spent today.
  /// Resets to 0 at the start of each new day (watch 0 = Dawn).
  /// When this reaches MAX_TRAVEL_WATCHES_PER_DAY (2), next travel signals Constitution save risk.
  watchesTraveledToday Int @default(0)

  /// Watches accumulated since last ration consumption.
  /// Ration fires at WILDERNESS_RATION_INTERVAL_WATCHES (6). Resets to 0 after deduction.
  watchesSinceRation Int @default(0)

  /// Watches since last weather recalculation.
  /// generateWeatherCheck fires at WEATHER_RECALC_INTERVAL_WATCHES (6). Resets to 0 after recalc.
  weatherWatchCounter Int @default(0)

  /// Sub-hex movement accumulator for Slow pace. Range: 0.0 to <1.0.
  /// Slow pace adds 0.5 per travel watch. When >= 1.0, a hex is crossed and value wraps mod 1.
  partialHexProgress Float @default(0.0)

  /// Persisted party pace setting. Overridable per-watch by executeTravelWatch input.
  /// "slow" | "normal" | "fast"
  partyPace String @default("normal")

  /// Current weather condition. Updated by generateWeatherCheck every 6 watches.
  /// "clear" | "overcast" | "rain" | "storm" | "fog" | "snow"
  weatherCondition String @default("clear")

  /// Weather severity: 0 = mild, 1 = moderate, 2 = severe.
  weatherIntensity Int @default(0)

  /// Season index fixed at campaign creation. 0=spring 1=summer 2=autumn 3=winter.
  /// Used by generateWeatherCheck to gate snow and adjust transition probabilities.
  seasonIndex Int @default(0)

  updatedAt DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id])
}
